# =========================

*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-shm
*.db-wal

postgres_data/
pgdata/
mysql_data/

# =========================
# Alembic / migrations
# =========================
# 通常 migrations/versions 应该提交。
# 如果你希望提交迁移文件，不要忽略 migrations/。
# 这里只忽略临时迁移缓存。

migrations/__pycache__/
migrations/**/*.pyc

# =========================
# Data files
# =========================
# 注意：样例数据可以放在 data/sample/ 并提交。
# 原始行情、处理后行情、真实交易数据不要提交。

data/raw/
data/processed/
data/cache/
data/tmp/
data/temp/
data/live/
data/broker/
data/private/

!data/sample/
!data/sample/**

*.csv
*.xlsx
*.xls
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle

# 允许提交样例数据
!data/sample/*.csv
!data/sample/*.xlsx
!data/sample/*.json
!data/sample/*.parquet

# =========================
# Quant / trading sensitive outputs
# =========================

reports/private/
reports/live/
reports/broker/
reports/account/
reports/trades/
reports/orders/

backtest_results/
optimize_results/
simulation_results/
live_results/

broker_logs/
trade_logs/
order_logs/
audit_exports/

