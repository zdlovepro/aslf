htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
.pytest_cache/
.mypy_cache/
.pyre/
.ruff_cache/
.hypothesis/
coverage.xml
*.cover
*.py,cover

# Type check
.dmypy.json
dmypy.json

# Jupyter
.ipynb_checkpoints/

# =========================
# Virtual environments
